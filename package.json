{
  "name": "simple-ai",
  "private": true,
  "version": "1.0.8",
  "type": "module",
  "main": "electron/main.cjs",
  "description": "一个面向新手的极简 AI 工具，配置 API 地址和 Key 即可使用",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "icons": "node scripts/gen-icons.mjs",
    "tauri": "tauri",
    "tauri:dev": "npm run icons && tauri dev",
    "tauri:build": "npm run icons && tauri build",
    "electron:dev": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "electron:build": "node scripts/bundle-claude.mjs && vite build --base ./ && electron-builder --win",
    "electron:pack": "node scripts/bundle-claude.mjs && vite build --base ./ && electron-builder --win --dir"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-updater": "^6.8.3",
    "fast-glob": "^3.3.3",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.0"
  },
  "author": {
    "name": "SimpleAI",
    "email": "support@simple-ai.app"
  },
  "build": {
    "appId": "com.simple-ai.toolbox",
    "productName": "简易AI工具箱",
    "artifactName": "SimpleAI-${version}-Setup.${ext}",
    "copyright": "Copyright © 2025-2026 SimpleAI",
    "directories": {
      "output": "out"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "A0be",
        "repo": "simple-ai"
      }
    ],
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!node_modules/**/{test,tests,__tests__}/**",
      "!node_modules/**/*.{md,map,ts}"
    ],
    "extraResources": [
      {
        "from": "public/icons/icon-512.png",
        "to": "icon.png"
      },
      {
        "from": "resources/claude/claude.exe",
        "to": "claude/claude.exe",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "npmRebuild": false,
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon-512.png",
      "legalTrademarks": "SimpleAI",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "shortcutName": "简易AI工具箱",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "简易AI工具箱"
    }
  }
}
