{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "简易 AI 工具箱",
  "version": "1.0.0",
  "identifier": "com.simpleai.toolbox",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "简易 AI 工具箱",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "dmg"],
    "category": "Productivity",
    "shortDescription": "极简 AI 工具，配置 API 即可使用",
    "longDescription": "面向新手的极简 AI 工具，无需登录，仅需 API 地址和 Key 即可使用。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installerIcon": "icons/icon.png",
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
